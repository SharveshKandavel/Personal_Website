{
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/client/assets/$1"
    },
    {
      "source": "/(.*\\.(jfif|png|jpg|jpeg|pdf|svg|ico))",
      "destination": "/dist/client/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
